{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.0.0",
  "default_locale": "zh_CN",
  "description": "__MSG_extensionDescription__",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "scripting",
    "tabs",
    "storage",
    "unlimitedStorage"
  ],
  "action": {
    "default_title": "ripfullpage",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "commands": {
    "full-page-capture": {
      "suggested_key": {
        "default": "Alt+Shift+F",
        "mac": "Alt+Shift+F"
      },
      "description": "__MSG_commandFullPage__"
    },
    "custom-area-capture": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "__MSG_commandCustomArea__"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
